# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=development          # development | production
APP_NAME="Locataire Cloud"
APP_VERSION=1.0.0
DEBUG=true

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=locataire_cloud
POSTGRES_USER=locataire_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── First Admin User (created on first startup) ───────────────────────────────
FIRST_ADMIN_EMAIL=admin@locataire-cloud.fr
FIRST_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
FIRST_ADMIN_NAME=Administrateur
