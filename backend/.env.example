# ── Copier ce fichier en .env et compléter les valeurs ─────────────────────────
# NE JAMAIS committer le fichier .env dans git

# ── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=LeComptoirImmo
APP_VERSION=1.0.0
DEBUG=false

# ── Sécurité ──────────────────────────────────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REMPLACER_PAR_UNE_CLE_SECRETE_64_CHARS

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Base de données PostgreSQL ─────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=locataire_cloud
POSTGRES_USER=locataire_user
POSTGRES_PASSWORD=REMPLACER_PAR_UN_MOT_DE_PASSE_FORT

# URL complète (construite automatiquement par Docker, sinon la renseigner manuellement)
DATABASE_URL=postgresql+asyncpg://locataire_user:REMPLACER_PAR_UN_MOT_DE_PASSE_FORT@postgres:5432/locataire_cloud

# ── CORS ──────────────────────────────────────────────────────────────────────
# En production, mettre uniquement le domaine de votre VPS
CORS_ORIGINS=https://votre-domaine.fr,https://www.votre-domaine.fr

# ── Premier administrateur (créé au premier démarrage si BDD vide) ─────────────
FIRST_ADMIN_EMAIL=admin@votre-domaine.fr
FIRST_ADMIN_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_ADMIN
FIRST_ADMIN_NAME=Administrateur
