<!DOCTYPE html>
<html lang="fr"><head><meta charset="UTF-8">
{% set sp = layout.spacing %}
<style>
  @page { size: A4; margin: {{ sp.page_margin }}; }
  body { font-family: Arial, sans-serif; font-size: {{ sp.font_size }}pt; color: #1f2937; line-height: {{ sp.line_height }}; background: #fff; }
  h1 { font-size: {{ sp.font_size | int + 6 }}pt; color: #0d2f5c; text-align: center; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 2px 0; }
  .sub { text-align: center; color: #6b7280; font-size: {{ sp.font_size | int - 1 }}pt; margin-bottom: 10px; }
  .head { display: flex; justify-content: space-between; gap: 20px; margin-bottom: 14px; }
  .box { flex: 1; border: 1px solid #e5e7eb; border-radius: 6px; padding: 8px 10px; }
  .box .lbl { font-size: {{ sp.font_size | int - 2 }}pt; color: #9ca3af; text-transform: uppercase; letter-spacing: .5px; }
  .box .val { font-weight: bold; color: #111827; }
  .res { border: 1px solid #e5e7eb; border-radius: 6px; margin-top: 12px; }
  .res .rh { padding: 6px 10px; font-weight: bold; border-bottom: 1px solid #eef2f7; }
  .res .rb { padding: 6px 10px; }
  .badge { font-size: {{ sp.font_size | int - 2 }}pt; padding: 2px 8px; border-radius: 9999px; }
  .ad { background: #dcfce7; color: #15803d; }
  .re { background: #fee2e2; color: #b91c1c; }
  .pe { background: #f3f4f6; color: #6b7280; }
  table { width: 100%; border-collapse: collapse; margin-top: 4px; }
  td, th { padding: 4px 8px; border-bottom: 1px solid #f1f5f9; font-size: {{ sp.font_size | int - 1 }}pt; text-align: left; }
  td.r, th.r { text-align: right; }
  .sign { margin-top: 22px; display: flex; align-items: flex-end; gap: 14px; }
  .footer { margin-top: 22px; border-top: 1px solid #e5e7eb; padding-top: 8px; font-size: 7.5pt; color: #9ca3af; }
</style></head><body>
  <h1>Procès-verbal d'assemblée générale</h1>
  <p class="sub">{{ ctx.title }}{% if ctx.meeting_date %} — {{ ctx.meeting_date.strftime('%d/%m/%Y') }}{% endif %}</p>

  <div class="head">
    <div class="box">
      <div class="lbl">Syndic</div>
      <div class="val">{{ manager_name }}</div>
    </div>
    <div class="box">
      <div class="lbl">Copropriété</div>
      <div class="val">{{ ctx.copro_name }}</div>
      {% if ctx.copro_address %}<div style="font-size:{{ sp.font_size | int - 2 }}pt;color:#6b7280;">{{ ctx.copro_address }}</div>{% endif %}
    </div>
  </div>

  {% for r in ctx.resolutions %}
  <div class="res">
    <div class="rh">
      Résolution {{ loop.index }} : {{ r.title }}
      {% if r.outcome == 'adopted' %}<span class="badge ad">Adoptée</span>
      {% elif r.outcome == 'rejected' %}<span class="badge re">Rejetée</span>
      {% else %}<span class="badge pe">Non soumise</span>{% endif %}
      {% if r.outcome_note %}<span style="font-size:{{ sp.font_size | int - 2 }}pt;color:#6b7280;"> · {{ r.outcome_note }}</span>{% endif %}
    </div>
    <div class="rb">
      {% if r.description %}<p style="margin:0 0 4px 0;">{{ r.description }}</p>{% endif %}
      <p style="margin:0;font-size:{{ sp.font_size | int - 2 }}pt;color:#6b7280;">Majorité : {{ r.majority_label }} · Base : {{ r.base_tantiemes }} tantièmes</p>
      <table>
        <tr><th>Pour</th><th>Contre</th><th>Abstention</th></tr>
        <tr>
          <td>{{ "%g"|format(r.pour) }}</td>
          <td>{{ "%g"|format(r.contre) }}</td>
          <td>{{ "%g"|format(r.abstention) }}</td>
        </tr>
      </table>
      {% if r.votes %}
      <table style="margin-top:6px;">
        <tr><th>Copropriétaire</th><th>Vote</th><th class="r">Tantièmes</th></tr>
        {% for v in r.votes %}
        <tr><td>{{ v.owner_name }}</td><td>{{ v.choice|capitalize }}</td><td class="r">{{ "%g"|format(v.tantiemes) }}</td></tr>
        {% endfor %}
      </table>
      {% endif %}
    </div>
  </div>
  {% endfor %}
  {% if not ctx.resolutions %}<p style="color:#9ca3af;">Aucune résolution.</p>{% endif %}

  {% if signature_uri or tampon_uri %}
  <div class="sign">
    {% if signature_uri %}<img src="{{ signature_uri }}" alt="Signature" width="150" height="75">{% endif %}
    {% if tampon_uri %}<img src="{{ tampon_uri }}" alt="Cachet" width="100" height="100" style="opacity:.92;">{% endif %}
  </div>
  {% endif %}

  <div class="footer">
    Procès-verbal établi par {{ manager_name }} (syndic) pour la copropriété {{ ctx.copro_name }}.
    Résultats des votes pondérés par les tantièmes de la clé générale. Document de gestion.
  </div>
</body></html>
