<!DOCTYPE html>
<html lang="fr"><head><meta charset="UTF-8">
{% set sp = layout.spacing %}
{% set f = data.fiscal %}
<style>
  @page { size: A4; margin: {{ sp.page_margin }}; }
  body { font-family: Arial, sans-serif; font-size: {{ sp.font_size }}pt; color: #1f2937; line-height: {{ sp.line_height }}; background: #fff; }
  h1 { font-size: {{ sp.font_size | int + 6 }}pt; color: #0d2f5c; text-align: center; text-transform: uppercase; letter-spacing: 1px; margin: 0 0 2px 0; }
  .sub { text-align: center; color: #6b7280; font-size: {{ sp.font_size | int - 1 }}pt; margin-bottom: 16px; }
  .owner { font-weight: bold; color: #111827; }
  h2 { font-size: {{ sp.font_size | int + 1 }}pt; color: #0d2f5c; border-left: 3px solid #0d2f5c; padding-left: 7px; margin: 18px 0 6px 0; }
  table { width: 100%; border-collapse: collapse; margin: 6px 0; }
  td, th { padding: 7px 10px; border-bottom: 1px solid #eef2f7; font-size: {{ sp.font_size }}pt; text-align: left; }
  th { background: #f3f4f6; color: #374151; }
  td.r, th.r { text-align: right; }
  tr.tot td { font-weight: bold; background: #eef2f7; border-top: 2px solid #0d2f5c; }
  .footer { margin-top: 24px; border-top: 1px solid #e5e7eb; padding-top: 8px; font-size: 8pt; color: #9ca3af; text-align: center; }
</style></head><body>
  <h1>Liasse fiscale</h1>
  <p class="sub">Revenus fonciers {{ data.year }} — <span class="owner">{{ data.owner_name }}</span></p>

  <h2>Synthèse des revenus fonciers</h2>
  <table>
    <tr><td>Loyers (hors charges) appelés</td><td class="r">{{ "%.2f"|format(f.loyers) }} €</td></tr>
    <tr><td>Provisions pour charges</td><td class="r">{{ "%.2f"|format(f.charges) }} €</td></tr>
    {% if f.apl and f.apl > 0 %}<tr><td>Aide personnelle au logement (tiers-payant)</td><td class="r">{{ "%.2f"|format(f.apl) }} €</td></tr>{% endif %}
    <tr class="tot"><td>Total appelé sur l'année</td><td class="r">{{ "%.2f"|format(f.total_du) }} €</td></tr>
    <tr class="tot"><td>Total encaissé sur l'année</td><td class="r">{{ "%.2f"|format(f.total_percu) }} €</td></tr>
  </table>

  <h2>Détail par bien</h2>
  <table>
    <tr><th>Bien</th><th class="r">Loyer + charges /mois</th><th class="r">Appelé {{ data.year }}</th><th class="r">Encaissé {{ data.year }}</th></tr>
    {% for b in data.biens %}
    <tr>
      <td>{{ b.property_name }}{% if b.city %} — {{ b.city }}{% endif %}</td>
      <td class="r">{{ "%.2f"|format(b.rent + b.charges) }} €</td>
      <td class="r">{{ "%.2f"|format(b.total_du) }} €</td>
      <td class="r">{{ "%.2f"|format(b.total_percu) }} €</td>
    </tr>
    {% endfor %}
    {% if not data.biens %}<tr><td colspan="4" style="color:#9ca3af;">Aucun bien rattaché.</td></tr>{% endif %}
  </table>

  <div class="footer">
    Document récapitulatif établi par Le Comptoir Immo à des fins d'aide à la déclaration des revenus fonciers ({{ data.year }}).
    Il ne se substitue pas aux justificatifs comptables ni à la déclaration officielle (formulaire 2044).
  </div>
</body></html>
